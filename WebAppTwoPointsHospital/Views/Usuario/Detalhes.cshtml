@model Usuario

@{
    ViewData["Title"] = "Detalhes";
}

<h1 class="">@ViewData["Title"]</h1>
<hr/>

<table class="table table-striped table-hover">
    <thead>
    <tr>
        <td>ID</td>
        <td>Nome</td>
        <td>Email</td>
        <td>Senha</td>
        <td>Cpf</td>
    </tr>
    </thead>
    <tbody>
    <tr>
        <td>@Model.UsuarioId</td>
        <td>@Model.Nome</td>
        <td>@Model.Email</td>
        <td>@Model.Senha</td>
        <td>@Model.Cpf</td>
    </tr>
    </tbody>
</table>

<div class="mt-4 w-100 d-flex justify-content-start">
    <a asp-controller="Usuario" asp-action="Usuarios" class="btn btn-success">
        Voltar para a Lista
    </a>
</div>
@model Usuario

@{
    ViewData["Title"] = "Login";
    Layout = "_Layout2";
    
}

<body class="bg-body-secondary">
<article class="d-flex vh-100 w-100 justify-content-center align-items-start mt-5">

    <section class="bg-success text-white p-5 rounded-3 shadow" style="min-width: 320px; max-width: 600px;">
        <h2 class="mb-4 text-center mb-5">Bem-vindo de volta!</h2>

        <p class="mb-4 text-center">Faça login para acessar o sistema</p>

        <form method="post" asp-action="Login">

            <div class="mb-3">
                <input type="email" name="email" class="form-control" placeholder="Email">
            </div>

            <div class="mb-3">
                <input type="password" name="senha" class="form-control" placeholder="Senha">
            </div>

            <button type="submit" class="btn btn-light w-100">Logar</button>

        </form>

        <div asp-validation-summary="ModelOnly" class="text-danger"></div>

        <div class="mt-3 text-center hoverEscurecer">
            <a class="text-white text-decoration-none" asp-action="Cadastro">Criar uma conta</a>
        </div>
    </section>

</article>
</body>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}






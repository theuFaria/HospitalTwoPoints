<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8"/>
    <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
    <title>@ViewData["Title"] - TwoPointsHospital</title>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css"/>
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true"/>
</head>

<body>

<header>
    <nav class="navbar navbar-expand-sm navbar-light bg-success border-bottom border-black box-shadow mb-3">
        <div class="container-fluid">

            <a class="navbar-brand" asp-controller="Usuario" asp-action="Login">
                Two Points
            </a>

            <button class="navbar-toggler" type="button"
                    data-bs-toggle="collapse"
                    data-bs-target=".navbar-collapse">
                <span class="navbar-toggler-icon"></span>
            </button>

            <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">

                <ul class="navbar-nav flex-grow-1">

                    <li class="nav-item">
                        <a class="nav-link text-dark"
                           asp-controller="Usuario"
                           asp-action="Login">
                            Login
                        </a>
                    </li>

                    <li class="nav-item">
                        <a class="nav-link text-dark"
                           asp-controller="Estoque"
                           asp-action="Consultar">
                            Consultar Estoque
                        </a>
                    </li>

                </ul>

            </div>
        </div>
    </nav>
</header>

<main class="container">
    @RenderBody()
</main>

<footer class="border-top footer text-muted mt-4">
    <div class="container">
        © 2026 - WebAppTwoPointsHospital
    </div>
</footer>

<script src="~/lib/jquery/dist/jquery.min.js"></script>
<script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
<script src="~/js/site.js"></script>

@await RenderSectionAsync("Scripts", required: false)

</body>
</html>